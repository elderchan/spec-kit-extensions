#!/usr/bin/env bash

# Portable SDD Hook
# Enforces Subagent-Driven Development (SDD) discipline.
# Checks spec.md status and task completeness before committing.

set -euo pipefail

echo ">>> Running SDD Pre-Commit Hook..."

INSIDE_GIT_WORK_TREE=false
REPO_ROOT=""
if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    INSIDE_GIT_WORK_TREE=true
    REPO_ROOT=$(git rev-parse --show-toplevel)
fi

to_repo_path() {
    local path="$1"

    if [ "$INSIDE_GIT_WORK_TREE" = true ]; then
        case "$path" in
            "$REPO_ROOT"/*)
                path="${path#$REPO_ROOT/}"
                ;;
            ./*)
                path="${path#./}"
                ;;
        esac
    fi

    printf '%s\n' "$path"
}

committed_file_exists() {
    local path="$1"

    if [ "$INSIDE_GIT_WORK_TREE" = true ]; then
        local repo_path
        repo_path=$(to_repo_path "$path")
        git ls-files --stage -- "$repo_path" | grep -q .
    else
        [ -f "$path" ]
    fi
}

read_committed_file() {
    local path="$1"

    if [ "$INSIDE_GIT_WORK_TREE" = true ]; then
        local repo_path
        repo_path=$(to_repo_path "$path")
        git show ":$repo_path"
    else
        cat "$path"
    fi
}

# Find spec.md or active feature spec
SPEC_FILE=""
if [ -n "${FEATURE_SPEC:-}" ] && committed_file_exists "$FEATURE_SPEC"; then
    SPEC_FILE="$FEATURE_SPEC"
elif committed_file_exists "spec.md"; then
    SPEC_FILE="spec.md"
else
    # Try to find a spec.md related to the staged files first
    while IFS= read -r -d '' STAGED_PATH; do
        DIR=$(dirname "$STAGED_PATH")
        if committed_file_exists "$DIR/spec.md"; then
            SPEC_FILE="$DIR/spec.md"
            break
        fi

        # Check parent directories up to root
        PARENT="$DIR"
        while [ "$PARENT" != "." ] && [ "$PARENT" != "/" ]; do
            PARENT=$(dirname "$PARENT")
            if committed_file_exists "$PARENT/spec.md"; then
                SPEC_FILE="$PARENT/spec.md"
                break
            fi
        done
        if [ -n "$SPEC_FILE" ]; then break; fi
    done < <(git diff --cached --name-only -z)
    
    # Fallback: search the workspace, silencing errors
    if [ -z "$SPEC_FILE" ]; then
        while IFS= read -r -d '' CANDIDATE_SPEC; do
            if committed_file_exists "$CANDIDATE_SPEC"; then
                SPEC_FILE="$CANDIDATE_SPEC"
                break
            fi
        done < <(find . -name "spec.md" -print0 2>/dev/null)
    fi
fi

if [ -z "$SPEC_FILE" ]; then
    echo "Info: No spec.md found in workspace. Skipping SDD checks."
    exit 0
fi

echo "Found specification: $SPEC_FILE"

# Detect Python
if command -v python3 >/dev/null 2>&1; then
  PYTHON_BIN="python3"
elif command -v python >/dev/null 2>&1 && python -c 'import sys; exit(0 if sys.version_info.major >= 3 else 1)'; then
  PYTHON_BIN="python"
else
  echo "Warning: Python 3 not found. Basic regex matching will be used instead."
  PYTHON_BIN=""
fi

# Extract status
STATUS=""
if [ -n "$PYTHON_BIN" ]; then
    STATUS=$(read_committed_file "$SPEC_FILE" | "$PYTHON_BIN" -c 'import re, sys; match = re.search(r"\*\*Status\*\*:\s*([^\r\n]+)", sys.stdin.read()); print(match.group(1).strip() if match else "")')
else
    STATUS=$(read_committed_file "$SPEC_FILE" | grep -i "\*\*Status\*\*:" | head -n 1 | cut -d: -f2- | xargs || true)
fi

echo "Current Spec Status: $STATUS"

if [ "$STATUS" = "Abandoned" ]; then
    echo "Warning: Feature status is set to Abandoned. Commits are permitted but discouraged."
    exit 0
fi

# Check tasks.md if it exists
TASKS_FILE=""
if committed_file_exists "tasks.md"; then
    TASKS_FILE="tasks.md"
else
    # Search in the same directory as the spec
    SPEC_DIR=$(dirname "$SPEC_FILE")
    if committed_file_exists "$SPEC_DIR/tasks.md"; then
        TASKS_FILE="$SPEC_DIR/tasks.md"
    fi
fi

if [ "$STATUS" = "Verified" ] && [ -z "$TASKS_FILE" ]; then
    echo "ERROR: Spec status is 'Verified' but no related tasks.md is staged for commit." >&2
    echo "Please add a completed tasks.md or revert status before committing." >&2
    exit 1
fi

if [ -n "$TASKS_FILE" ]; then
    echo "Found tasks checklist: $TASKS_FILE"
    
    # If status is Verified, ensure there are no uncompleted tasks [ ] in tasks.md
    if [ "$STATUS" = "Verified" ]; then
        UNCOMPLETED=$(read_committed_file "$TASKS_FILE" | grep -E '^\s*[-*]\s*\[\s*\]' | wc -l | xargs || true)
        if [ "$UNCOMPLETED" -ne 0 ]; then
            echo "ERROR: Spec status is 'Verified' but tasks.md contains $UNCOMPLETED uncompleted tasks [ ]." >&2
            echo "Please complete all tasks or revert status before committing." >&2
            exit 1
        fi
    fi
fi

echo ">>> SDD check passed successfully!"
exit 0
